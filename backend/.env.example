# ── Database ──
DATABASE_URL="postgresql://user:password@localhost:5432/erms"

# ── JWT ──
JWT_SECRET="change_me_to_a_long_random_string"
JWT_EXPIRES_IN="7d"

# ── Redis ──
REDIS_URL="redis://localhost:6379"

# ── App ──
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://127.0.0.1:5173"

# ── Email (optional — used for OTP in production) ──
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@planningcenter.com"
